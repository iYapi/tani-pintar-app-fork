{
  "info": {
    "name": "Tani Pintar API",
    "description": "Koleksi Postman untuk seluruh endpoint Tani Pintar.\n\nBase URL: http://localhost:3000\nMock Auth aktif — set MOCK_AUTH_USER_ID & MOCK_AUTH_ROLE di environment.\n\nDokumen kontrak: docs/api-contract.md",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "mock_user_petani",
      "value": "dev-petani-001",
      "type": "string"
    },
    {
      "key": "mock_user_buyer",
      "value": "dev-buyer-001",
      "type": "string"
    },
    {
      "key": "internal_secret",
      "value": "dev-internal-secret-change-in-production",
      "type": "string"
    },
    {
      "key": "land_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "harvest_plan_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "demand_listing_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "sale_listing_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "match_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "phone_number",
      "value": "628123456789",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "OTP-based registration + login (dikembangkan oleh rekan).",
      "item": [
        {
          "name": "POST Register (kirim OTP)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Test Petani\",\n  \"phoneNumber\": \"{{phone_number}}\",\n  \"role\": \"farmer\"\n}"
            }
          }
        },
        {
          "name": "POST Verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/auth/verify-otp",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "verify-otp"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"{{phone_number}}\",\n  \"otp\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "POST Login (kirim OTP)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"{{phone_number}}\"\n}"
            }
          }
        },
        {
          "name": "POST Resend OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/auth/resend-otp",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "resend-otp"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"{{phone_number}}\",\n  \"purpose\": \"REGISTER\"\n}"
            }
          }
        },
        {
          "name": "POST Logout",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "logout"]
            }
          }
        }
      ]
    },
