    {
      "name": "Matching",
      "description": "Auto-matching engine (FR-12).\n\nMatch dihasilkan oleh /matching/run (stub). /matches/* untuk accept/reject/transact.",
      "item": [
        {
          "name": "POST Trigger Matching Run (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/matching/run",
              "host": ["{{base_url}}"],
              "path": ["api", "matching", "run"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"filters\": {\n    \"commodity\": \"Bawang Merah\"\n  }\n}"
            }
          }
        },
        {
          "name": "GET Matching Job Status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/matching/jobs/test-job-id",
              "host": ["{{base_url}}"],
              "path": ["api", "matching", "jobs", "test-job-id"]
            }
          }
        },
        {
          "name": "GET My Matches (list)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/matches?status=PROPOSED&minScore=50&page=1&pageSize=10",
              "host": ["{{base_url}}"],
              "path": ["api", "matches"],
              "query": [
                { "key": "status", "value": "PROPOSED", "disabled": true },
                { "key": "minScore", "value": "50", "disabled": true },
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "GET Match Detail",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/matches/{{match_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "matches", "{{match_id}}"]
            }
          }
        },
        {
          "name": "PATCH Accept Match",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/matches/{{match_id}}/accept",
              "host": ["{{base_url}}"],
              "path": ["api", "matches", "{{match_id}}", "accept"]
            }
          }
        },
        {
          "name": "PATCH Reject Match",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/matches/{{match_id}}/reject",
              "host": ["{{base_url}}"],
              "path": ["api", "matches", "{{match_id}}", "reject"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Harga terlalu rendah\"\n}"
            }
          }
        },
