    {
      "name": "Notifications",
      "description": "WhatsApp notifications (FR-13, FR-14, FR-15).\n\nWebhook untuk incoming WA. Send untuk kirim notifikasi via WA API.\nInternal endpoints dilindungi X-Internal-Secret.",
      "item": [
        {
          "name": "POST Webhook (incoming WA)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/notifications/webhook",
              "host": ["{{base_url}}"],
              "path": ["api", "notifications", "webhook"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"From\": \"{{phone_number}}\",\n  \"Body\": \"harga bawang merah\"\n}"
            }
          }
        },
        {
          "name": "POST Send Notification (internal)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Internal-Secret", "value": "{{internal_secret}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/notifications/send",
              "host": ["{{base_url}}"],
              "path": ["api", "notifications", "send"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{mock_user_petani}}\",\n  \"channel\": \"WHATSAPP\",\n  \"type\": \"OVERSUPPLY_ALERT\",\n  \"messageContent\": \"⚠️ Deteksi potensi oversupply bawang merah di wilayah Anda. Harga proyeksi turun 12%.\",\n  \"toAddress\": \"628123456789\"\n}"
            }
          }
        },
        {
          "name": "POST Quick Query (internal)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Internal-Secret", "value": "{{internal_secret}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/notifications/quick-query",
              "host": ["{{base_url}}"],
              "path": ["api", "notifications", "quick-query"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"{{phone_number}}\",\n  \"query\": \"harga bawang merah hari ini\"\n}"
            }
          }
        },
        {
          "name": "GET Notification Log",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/notifications?status=DELIVERED&page=1&pageSize=10",
              "host": ["{{base_url}}"],
              "path": ["api", "notifications"],
              "query": [
                { "key": "status", "value": "DELIVERED", "disabled": true },
                { "key": "channel", "value": "WHATSAPP", "disabled": true },
                { "key": "type", "value": "", "disabled": true },
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "10" }
              ]
            }
          }
        }
      ]
    },
